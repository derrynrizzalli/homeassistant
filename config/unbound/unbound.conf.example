server:
    # Listen on all interfaces (IPv4 + IPv6)
    interface: 0.0.0.0
    interface: ::0
    port: 5353

    # Access control
    access-control: 10.1.1.0/24 allow
    access-control: 10.1.2.0/24 allow
    access-control: 10.1.3.0/24 allow
    access-control: 10.1.4.0/24 allow
    access-control: 2401:d002:3a00::/48 allow
    access-control: fd00::/10 allow
    access-control: fe80::/10 allow

    # Enable IPv6 support
    do-ip6: yes
    prefer-ip6: yes

    # Performance tuning
    num-threads: 2
    msg-cache-slabs: 4
    rrset-cache-slabs: 4
    infra-cache-slabs: 4
    key-cache-slabs: 4

    # Cache sizes
    rrset-cache-size: 100m
    msg-cache-size: 50m

    # Privacy
    hide-identity: yes
    hide-version: yes

    # Security
    harden-glue: yes
    harden-dnssec-stripped: yes
    use-caps-for-id: yes

    # DNSSEC
    auto-trust-anchor-file: "/var/lib/unbound/root.key"

    # TLS settings
    tls-cert-bundle: /etc/ssl/certs/ca-certificates.crt

    # Logging
    verbosity: 2
    log-queries: yes
    log-replies: yes
    use-syslog: no
    logfile: ""   # empty = stdout


forward-zone:
    name: "."
    forward-tls-upstream: yes

    # Cloudflare DNS over TLS
    forward-addr: 1.1.1.1@853#cloudflare-dns.com
    forward-addr: 1.0.0.1@853#cloudflare-dns.com
    forward-addr: 2606:4700:4700::1111@853#cloudflare-dns.com
    forward-addr: 2606:4700:4700::1001@853#cloudflare-dns.com
